---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServicePageBody from '../../components/ServicePageBody.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
---

<Layout
  title="Website Design & Development | Astrova Systems"
  description="Clean, modern, high-converting websites built for auto shops and home service businesses that need to look credible and turn visitors into paying clients."
>
  <ScrollReveal />
  <Header />
  <main>
    <Breadcrumbs items={[
      { name: 'Home', url: '/' },
      { name: 'Services', url: '/#services' },
      { name: 'Website Design', url: '/services/website-design' },
    ]} />
    <ServicePageBody
      eyebrow="Website Design & Development"
      h1="Websites Built to Convert Visitors Into Booked Customers"
      intro="Astrova Systems designs and builds fast, modern websites for auto shops and home service businesses. Every site is built with one goal: turn the traffic you're already earning or paying for into calls, form fills, and booked jobs."
      whatsIncluded={[
        'Custom website design tailored to your brand, services, and service area',
        'Mobile-first, fast-loading pages built for both visitors and search engines',
        'Clear calls-to-action and booking flows on every page',
        'On-page SEO fundamentals baked in from day one (titles, headings, structured data)',
        'Ongoing hosting, updates, and support after launch',
      ]}
      whoItsFor={[
        'Auto shops and tint shops whose current site doesn\'t reflect the quality of their work',
        'Home service businesses without a website, or with one that isn\'t generating leads',
        'Businesses running paid ads that need a landing page built to actually convert traffic',
        'Owners who want a site that supports SEO, ads, and lead systems together, not in isolation',
      ]}
      resultsToExpect={[
        'A professional, credible online presence that matches the quality of your work',
        'Higher conversion rates from the traffic you already have, whether organic or paid',
        'A site built to support SEO growth and paid campaigns instead of working against them',
        'A foundation that scales with you as you add lead systems and marketing channels',
      ]}
      relatedLinks={[
        { label: 'Local SEO for automotive & home service businesses', href: '/services/local-seo' },
        { label: 'Lead Systems & CRM Automation', href: '/services/lead-systems' },
        { label: 'Local SEO for Auto Shops: How to Rank on Google Without Paying for Ads', href: '/blog/local-seo-for-auto-shops' },
      ]}
    />
  </main>
  <CTASection />
  <Footer />
</Layout>
