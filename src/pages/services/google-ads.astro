---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServicePageBody from '../../components/ServicePageBody.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
---

<Layout
  title="Google Ads Management | Astrova Systems"
  description="Done-for-you Google Ads management for auto shops and home service businesses. Strategic search campaigns built to capture high-intent leads and grow revenue."
>
  <ScrollReveal />
  <Header />
  <main>
    <Breadcrumbs items={[
      { name: 'Home', url: '/' },
      { name: 'Services', url: '/#services' },
      { name: 'Google Ads', url: '/services/google-ads' },
    ]} />
    <ServicePageBody
      eyebrow="Google Ads"
      h1="Google Ads Management That Brings In Ready-to-Buy Customers"
      intro="Astrova Systems builds and manages Google Ads campaigns for auto shops and home service businesses, targeting people who are actively searching for what you sell right now. No guesswork, no wasted spend — just campaigns built around keywords, ad copy, and landing pages that turn clicks into booked jobs."
      whatsIncluded={[
        'Search campaign strategy and keyword research built around high-intent buyer terms',
        'Ad copywriting and A/B testing to improve click-through and conversion rates',
        'Conversion tracking so every call, form fill, and booking is measured',
        'Landing page recommendations that pair with your Google Ads traffic',
        'Monthly reporting and ongoing optimization based on real campaign data',
      ]}
      whoItsFor={[
        'Auto shops, tint shops, and detailing businesses that want more booked jobs, not just clicks',
        'Home service businesses competing for local searches like "near me" and "emergency" terms',
        'Businesses that already have steady demand but want to scale predictably',
        'Owners who want a managed campaign instead of guessing inside Google Ads themselves',
      ]}
      resultsToExpect={[
        'A campaign structure built around your highest-intent search terms within the first few weeks',
        'Clearer cost-per-lead data so you know exactly what a new customer costs to acquire',
        'A steady flow of inbound calls and form submissions from people ready to buy',
        'Ongoing optimization as campaigns collect more data and improve over time',
      ]}
      relatedLinks={[
        { label: 'Meta Ads management', href: '/services/meta-ads' },
        { label: 'Lead Systems & CRM Automation', href: '/services/lead-systems' },
        { label: 'How Window Tint Shops Can Get More Customers with Google Ads', href: '/blog/google-ads-for-window-tint-shops' },
      ]}
    />
  </main>
  <CTASection />
  <Footer />
</Layout>
