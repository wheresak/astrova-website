---
const year = new Date().getFullYear();
---

<footer class="py-12 md:py-16">
  <div class="mx-auto max-w-6xl px-6 flex flex-col md:flex-row md:items-start md:justify-between gap-10">
    <div>
      <div class="flex items-center gap-2.5 mb-2">
        <img src="/images/astrova-icon.png" alt="Astrova Systems Logo" width="24" height="24" class="w-6 h-6 object-contain" />
        <p class="font-display text-lg font-semibold tracking-tight">
          Astrova<span class="text-accent">.</span>
        </p>
      </div>
      <p class="text-muted text-sm max-w-xs">
        Auto shop scaling through ads, websites, and systems.
      </p>
    </div>

    <div class="flex flex-wrap gap-x-12 gap-y-8">
      <nav class="flex flex-col gap-2" aria-label="Services">
        <p class="text-xs font-medium tracking-[0.15em] text-muted uppercase mb-1">Services</p>
        <a href="/services/google-ads" class="text-sm text-muted hover:text-paper transition-colors">Google Ads</a>
        <a href="/services/meta-ads" class="text-sm text-muted hover:text-paper transition-colors">Meta Ads</a>
        <a href="/services/website-design" class="text-sm text-muted hover:text-paper transition-colors">Website Design</a>
        <a href="/services/lead-systems" class="text-sm text-muted hover:text-paper transition-colors">Lead Systems</a>
        <a href="/services/local-seo" class="text-sm text-muted hover:text-paper transition-colors">Local SEO</a>
      </nav>

      <nav class="flex flex-col gap-2" aria-label="Company">
        <p class="text-xs font-medium tracking-[0.15em] text-muted uppercase mb-1">Company</p>
        <a href="/about" class="text-sm text-muted hover:text-paper transition-colors">About</a>
        <a href="/blog" class="text-sm text-muted hover:text-paper transition-colors">Blog</a>
        <a href="/testimonials" class="text-sm text-muted hover:text-paper transition-colors">Testimonials</a>
        <a href="/contact" class="text-sm text-muted hover:text-paper transition-colors">Contact</a>
      </nav>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-6 mt-10 pt-6 border-t border-border-hair">
    <p class="text-xs text-muted">&copy; {year} Astrova Systems. All rights reserved.</p>
  </div>
</footer>
