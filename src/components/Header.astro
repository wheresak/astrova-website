---
const navLinks = [
  {
    label: 'Services',
    href: '/#services',
    children: [
      { label: 'Google Ads', href: '/services/google-ads' },
      { label: 'Meta Ads', href: '/services/meta-ads' },
      { label: 'Website Design', href: '/services/website-design' },
      { label: 'Lead Systems', href: '/services/lead-systems' },
      { label: 'Local SEO', href: '/services/local-seo' },
    ],
  },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Testimonials', href: '/testimonials' },
  { label: 'Contact', href: '/contact' },
];
const bookingUrl = 'https://api.leadconnectorhq.com/widget/booking/xEVsaKBDh9Rr3ZqeVl0z';
---

<header class="sticky top-0 z-50 border-b border-border-hair bg-ink/90 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-6 flex items-center justify-between h-18 py-4">
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <img src="/images/astrova-icon.png" alt="Astrova Systems Logo" width="28" height="28" class="w-7 h-7 object-contain" />
       <span class="font-display text-lg font-semibold tracking-tight">
      Astrova<span class="text-accent">.</span>
       </span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Primary">
      {navLinks.map((link) => (
        link.children ? (
          <div class="relative group">
            <a
              href={link.href}
              class="inline-flex items-center gap-1 text-sm text-muted hover:text-paper transition-colors py-2"
            >
              {link.label}
              <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <div class="absolute left-0 top-full w-56 pt-2 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 transition-all duration-150">
              <div class="rounded-xl border border-border-hair bg-surface-raised overflow-hidden py-2 shadow-lg">
                {link.children.map((child) => (
                  <a href={child.href} class="block px-4 py-2.5 text-sm text-muted hover:text-paper hover:bg-surface transition-colors">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class="text-sm text-muted hover:text-paper transition-colors"
          >
            {link.label}
          </a>
        )
      ))}
    </nav>

    <a
      href={bookingUrl}
      class="hidden md:inline-flex items-center justify-center rounded-md bg-accent text-ink text-sm font-medium px-5 py-2.5 transition hover:bg-accent-dim"
    >
      Book a call
    </a>

    <button
      id="menu-toggle"
      type="button"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 -mr-2 text-paper"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Mobile"
    class="md:hidden hidden border-t border-border-hair bg-ink"
  >
    <div class="flex flex-col px-6 py-4">
      {navLinks.map((link) => (
        <div class="border-b border-border-hair last:border-0 py-1">
          <a href={link.href} class="block text-base text-paper py-2">
            {link.label}
          </a>
          {link.children && (
            <div class="flex flex-col pb-2">
              {link.children.map((child) => (
                <a href={child.href} class="text-sm text-muted py-2 pl-3">
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <a
        href={bookingUrl}
        class="mt-4 inline-flex items-center justify-center rounded-md bg-accent text-ink text-sm font-medium px-5 py-3"
      >
        Book a call
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
