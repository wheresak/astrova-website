---
const steps = [
  {
    label: 'Attract',
    description: 'Use Google and Meta Ads to drive qualified traffic and leads.',
  },
  {
    label: 'Convert',
    description: 'Send traffic to a polished website or landing page built to convert.',
  },
  {
    label: 'Scale',
    description: 'Use automation and systems to follow up faster and grow with consistency.',
  },
];
---

<section class="border-b border-border-hair py-24 md:py-32 overflow-hidden">
  <div class="mx-auto max-w-6xl px-6">
    <p class="font-display text-xs font-medium tracking-[0.2em] text-accent uppercase mb-4" data-reveal>
      How it works
    </p>
    <h2 class="font-display text-3xl md:text-5xl font-medium leading-tight max-w-xl mb-16 md:mb-24" data-reveal style="--reveal-delay: 80ms">
      A full client acquisition system
    </h2>

    <div class="relative">
      <div class="hidden md:block absolute top-3 left-0 right-0 h-px bg-border-hair">
        <div id="process-line" class="h-px bg-accent origin-left scale-x-0 transition-transform duration-[1200ms] ease-out"></div>
      </div>
      <div class="md:hidden absolute top-1 bottom-1 left-3 w-px bg-border-hair">
        <div id="process-line-mobile" class="w-px bg-accent origin-top scale-y-0 transition-transform duration-[1200ms] ease-out h-full"></div>
      </div>

      <ol class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
        {steps.map((step, i) => (
          <li class="relative pl-10 md:pl-0" data-reveal style={`--reveal-delay: ${i * 140}ms`}>
            <span class="absolute left-0 top-1 md:relative md:top-0 md:block w-6 h-6 rounded-full bg-ink border-2 border-accent mb-6 process-node" style={`--node-delay: ${i * 250}ms`}></span>
            <span class="block text-xs font-medium tracking-[0.15em] text-muted uppercase mb-3 md:mt-2">
              Step {i + 1}
            </span>
            <h3 class="font-display text-2xl font-medium mb-2">{step.label}</h3>
            <p class="text-muted text-sm md:text-base leading-relaxed max-w-xs">{step.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .process-node {
    transition: background-color 0.4s ease, transform 0.4s ease;
    transition-delay: var(--node-delay, 0ms);
  }
  .process-node.is-active {
    background-color: var(--color-accent);
    transform: scale(1.15);
  }
</style>

<script>
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const section = document.currentScript?.closest('section');
  const line = document.getElementById('process-line');
  const lineMobile = document.getElementById('process-line-mobile');
  const nodes = section?.querySelectorAll('.process-node');

  function activate() {
    line?.classList.remove('scale-x-0');
    lineMobile?.classList.remove('scale-y-0');
    nodes?.forEach((n) => n.classList.add('is-active'));
  }

  if (section) {
    if (reduceMotion) {
      activate();
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              activate();
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.4 }
      );
      observer.observe(section);
    }
  }
</script>
