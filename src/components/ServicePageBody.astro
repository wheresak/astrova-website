---
interface RelatedLink {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  h1: string;
  intro: string;
  whatsIncluded: string[];
  whoItsFor: string[];
  resultsToExpect: string[];
  relatedLinks: RelatedLink[];
}

const { eyebrow, h1, intro, whatsIncluded, whoItsFor, resultsToExpect, relatedLinks } = Astro.props;
---

<section class="border-b border-border-hair pt-16 md:pt-20 pb-24 md:pb-32">
  <div class="mx-auto max-w-4xl px-6">
    <p class="font-display text-xs font-medium tracking-[0.2em] text-accent uppercase mb-4">
      {eyebrow}
    </p>
    <h1 class="font-display text-3xl md:text-5xl font-medium leading-tight mb-6">
      {h1}
    </h1>
    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl">
      {intro}
    </p>
  </div>
</section>

<section class="border-b border-border-hair py-16 md:py-20">
  <div class="mx-auto max-w-4xl px-6">
    <h2 class="font-display text-2xl md:text-3xl font-medium leading-tight mb-8">What's included</h2>
    <ul class="space-y-4">
      {whatsIncluded.map((item) => (
        <li class="flex gap-3 text-muted text-sm md:text-base leading-relaxed">
          <span class="text-accent mt-1" aria-hidden="true">&#10003;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="border-b border-border-hair py-16 md:py-20">
  <div class="mx-auto max-w-4xl px-6">
    <h2 class="font-display text-2xl md:text-3xl font-medium leading-tight mb-8">Who it's for</h2>
    <ul class="space-y-4">
      {whoItsFor.map((item) => (
        <li class="flex gap-3 text-muted text-sm md:text-base leading-relaxed">
          <span class="text-accent mt-1" aria-hidden="true">&#10003;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="border-b border-border-hair py-16 md:py-20">
  <div class="mx-auto max-w-4xl px-6">
    <h2 class="font-display text-2xl md:text-3xl font-medium leading-tight mb-8">Results to expect</h2>
    <ul class="space-y-4">
      {resultsToExpect.map((item) => (
        <li class="flex gap-3 text-muted text-sm md:text-base leading-relaxed">
          <span class="text-accent mt-1" aria-hidden="true">&#10003;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

{relatedLinks.length > 0 && (
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="font-display text-2xl md:text-3xl font-medium leading-tight mb-6">Related</h2>
      <ul class="flex flex-wrap gap-x-8 gap-y-3">
        {relatedLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-accent hover:text-accent-dim transition-colors">
              {link.label} &rarr;
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
